    },
    {
      "label": "wrong_storage_256",
      "pattern": "(?:^|[^0-9])256\\s*(?:gb|기가)?\\b"
    },
    {
      "label": "wrong_storage_512_1tb",
      "pattern": "512\\s*(?:gb|기가)?|1\\s*tb|1\\s*테라"
    },
    {
      "label": "carrier_skt",
      "pattern": "\\bskt\\b|sk\\s*텔레콤|에스케이\\s*텔레콤"
    },
    {
      "label": "carrier_kt",
