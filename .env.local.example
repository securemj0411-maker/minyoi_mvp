NEXT_PUBLIC_SUPABASE_URL=https://suwsvvjsycgcegepcktp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_rotated_service_role_key

# PortOne V2 / KG이니시스 테스트 채널.
# Store ID와 channel key는 브라우저 결제창 호출에 쓰이는 공개 식별자입니다.
NEXT_PUBLIC_PORTONE_STORE_ID=store-670b9708-35fd-4e46-9cd0-48b5c0e56f6a
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=channel-key-69134205-c63b-46d9-b389-aff785c8dfe3
# 서버 결제 검증용 V2 API Secret. production에서는 필수입니다.
PORTONE_API_SECRET=replace_with_portone_v2_api_secret
# 로컬 개발에서 API Secret 없이 결제창 UI만 테스트할 때만 1로 설정하세요.
PORTONE_SKIP_VERIFY=0

# Optional. Used only by the pipeline's narrow Tier 2 review for top suspicious candidates.
OPENAI_API_KEY=replace_with_openai_key
OPENAI_CLASSIFIER_MODEL=gpt-4.1-mini

# Wave 238 (2026-05-19): AI L2 shadow audit — ready pool 매물 중 AI 안 본 매물 강제 호출.
# baseline 91.1% AI 안 봄 → fashion mismatch 근본 source. iPad/tech 패턴 catalog 학습 loop.
# AI_L2_SHADOW_AUDIT_ENABLED=1 (default on) / 0 (disable)
AI_L2_SHADOW_AUDIT_ENABLED=1
# Daily budget cap (USD). 초과 시 자동 disable + telegram alert.
AI_L2_DAILY_BUDGET_USD=10
# Per-tick cap — 한 번 tick 안 audit 최대 매물 수.
AI_L2_SHADOW_AUDIT_PER_TICK_CAP=50
# Concurrency — AI 호출 parallel 수 (rate limit 안전).
AI_L2_SHADOW_AUDIT_CONCURRENCY=3

# Pipeline knobs. All are optional; URL query params can override these for one run.
PIPELINE_SEARCH_QUERIES=에어팟,에어팟 프로,에어팟 프로2,에어팟 4세대,에어팟 맥스,애플워치,애플워치 se,애플워치 9,애플워치 10,애플워치 울트라,갤럭시워치,갤럭시 워치 6,갤럭시 워치 7,갤럭시 워치 울트라
PIPELINE_PAGES_PER_QUERY=1
PIPELINE_MAX_PAGES_PER_QUERY=1
PIPELINE_SEARCH_DELAY_MS=100
PIPELINE_DEEP_CRAWL_MAX_PAGE=3
PIPELINE_DETAIL_LIMIT=60
PIPELINE_MAX_DETAIL_LIMIT=60
PIPELINE_DETAIL_CONCURRENCY=2
PIPELINE_MAX_DETAIL_CONCURRENCY=2
PIPELINE_DETAIL_DELAY_MS=300
PIPELINE_AI_REVIEW_TOP_N=10
PIPELINE_MAX_AI_REVIEW_TOP_N=10
PIPELINE_AI_REVIEW_CONCURRENCY=2
PIPELINE_MAX_AI_REVIEW_CONCURRENCY=2
PIPELINE_STALE_RUN_MINUTES=3
PIPELINE_TICK_SEARCH_BUDGET_MS=8000
PIPELINE_TICK_SEARCH_QUERY_LIMIT=40
PIPELINE_TICK_DETAIL_BUDGET_MS=20000
PIPELINE_TICK_SCORE_BUDGET_MS=10000
PIPELINE_SCORE_WORKER_BUDGET_MS=55000
PIPELINE_TICK_DETAIL_BATCH_SIZE=20
PIPELINE_TICK_DETAIL_LEASE_SECONDS=90
PIPELINE_TICK_SCORE_LIMIT=300
PIPELINE_TICK_INLINE_SCORE_ENABLED=false

# Optional I/O reducer for unchanged active search sightings.
# Keep dry-run=true first to estimate saved writes; set the active flag only after
# pack-open/live freshness remains healthy.
RAW_TOUCH_COALESCE_ACTIVE_SEEN_ONLY=false
RAW_TOUCH_COALESCE_ACTIVE_SEEN_ONLY_DRY_RUN=false
RAW_TOUCH_COALESCE_ACTIVE_SEEN_ONLY_WINDOW_MS=600000
PIPELINE_TERMINAL_LIFECYCLE_RECHECK_BATCH_SIZE=10

# Cron guard knobs. Skip responses are HTTP 200 and do not create collect-run rows.
CRON_GUARD_SOURCE_HEALTH_ENABLED=true
CRON_GUARD_SOURCE_HEALTH_STALE_MS=600000
CRON_GUARD_COOLDOWN_MS_LIFECYCLE_TERMINAL_RECHECK=300000
CRON_GUARD_LEASE_MS_LIFECYCLE_TERMINAL_RECHECK=120000

# Optional. Only needed when creating the Upstash QStash schedule from CLI.
QSTASH_TOKEN=replace_with_qstash_token
APP_BASE_URL=https://your-production-domain.example
QSTASH_TERMINAL_RECHECK_CRON=*/5 * * * *
QSTASH_TERMINAL_RECHECK_SCHEDULE_ID=minyoi-lifecycle-terminal-recheck-v1

# Optional. Sends worker failure/recovery alerts. If unset, alerts stay visible in /debug only.
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_ALERT_CHAT_ID=replace_with_telegram_chat_id

# Optional. If true, Next server reads local PoC JSON instead of Supabase.
USE_LOCAL_POC_DATA=false

# P1-13: admin email allowlist (comma-separated). 비워두면 코드 하드코딩 fallback만 적용.
# 권한 추가/회수는 이 env 갱신으로 처리 가능(배포 불필요).
ADMIN_EMAILS=

# P0-3: cron guard에 DB lease 보강 활성. 멀티 인스턴스 동시 실행 차단.
# 기본 비활성(메모리 guard만 사용). production에서 1로 켤 것.
CRON_GUARD_DB_LOCK_ENABLED=0

# Joongna source mode.
# active writes source=joongna rows with pool_eligible=true / score_dirty=true.
JOONGNA_SOURCE_MODE=active
# Seed queries only. Runtime also appends rotating public-ready catalog SKU queries.
JOONGNA_INGEST_QUERIES=에어팟맥스,아이폰 17 프로,아이패드 프로,애플워치,맥북
JOONGNA_INGEST_QUERY_LIMIT=80
JOONGNA_INGEST_MAX_DETAILS=80
JOONGNA_INGEST_DETAILS_PER_QUERY=2
JOONGNA_INGEST_DELAY_MS=200
JOONGNA_INGEST_TIMEOUT_MS=10000

# /api/debug/reset-db 전용 시크릿. CRON_SECRET fallback 제거됨 — 명시 필수.
# production에서는 ALLOW_DEBUG_RESET=1 도 함께 설정해야 라우트가 열림.
DEBUG_RESET_SECRET=
ALLOW_DEBUG_RESET=0

# P0-3: 유료 API rate limiter. 1=활성. infra 장애 시 fail-open(허용).
# 어드민 계정은 항상 우회.
RATE_LIMIT_ENABLED=0
PACKS_OPEN_RATE_LIMIT_MAX=5
PACKS_OPEN_RATE_LIMIT_WINDOW_SECONDS=10
# P1-C: 읽기 엔드포인트 rate limit. inventory는 공개라 IP 기준, 나머지는 user 기준.
PACKS_INVENTORY_RATE_LIMIT_MAX=30
PACKS_INVENTORY_RATE_LIMIT_WINDOW_SECONDS=10
PACKS_ME_RATE_LIMIT_MAX=10
PACKS_ME_RATE_LIMIT_WINDOW_SECONDS=10
CREDITS_ME_RATE_LIMIT_MAX=30
CREDITS_ME_RATE_LIMIT_WINDOW_SECONDS=10

# Sentry — 에러 추적 (audit CRITICAL #7)
# DSN 은 sentry.io 대시보드 → Settings → Client Keys.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Source map upload 용 (선택). Sentry → Settings → Auth Tokens.
# SENTRY_AUTH_TOKEN=
